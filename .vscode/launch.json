{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--enable-proposed-api=dev-chaos-sounds.dev-chaos-sounds"
      ],
      "outFiles": ["${workspaceFolder}/out/**/*.js"]
    }
  ]
}
